@model string
@{
    ViewData["Title"] = "Room not found";
}

<div class="landing">
    <div class="landing-head">
        <p class="kicker">Error &middot; 404</p>
        <h1 class="wordmark">No room here</h1>
        <p class="lede">There&rsquo;s no room with the code <strong>@Model</strong>. Check the code, or start a fresh one.</p>
    </div>
    <a class="btn primary" asp-controller="Home" asp-action="Index">Back home</a>
</div>
